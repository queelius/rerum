    "examples": [{"in": "(sub (s z) (s z))", "out": "(pred (sub (s z) z))"}]
  },
  "even-zero": {
    "category": "parity",
    "examples": [{"in": "(even? z)", "out": "true"}]
  },
  "even-succ": {
