  "mul-zero": {
    "category": "multiplication",
    "examples": [{"in": "(mul z (s z))", "out": "z"}]
  },
  "mul-succ": {
    "category": "multiplication",
    "reasoning": "Multiplication as iterated addition: (1+m)*n = n + m*n.",
