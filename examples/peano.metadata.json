    "reasoning": "Mutual recursion with odd?: parity flips per successor.",
    "examples": [{"in": "(even? (s z))", "out": "(odd? z)"}]
  },
  "odd-zero": {
    "category": "parity",
    "examples": [{"in": "(odd? z)", "out": "false"}]
  },
  "odd-succ": {
    "category": "parity",
    "examples": [{"in": "(odd? (s z))", "out": "(even? z)"}]
  },
  "le-zero": {
    "category": "comparison",
    "examples": [{"in": "(le z (s z))", "out": "true"}]
