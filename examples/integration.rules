# Integration rules over the (int f v) operator. DEMONSTRATION content.
# Reduced by goal-directed search (rerum.solve.solve): integration is
# NON-CONFLUENT (table, linearity, u-sub, and by-parts compete), so the
# driver is solve with the caller-supplied goal "no int operator remains".
# examples metadata lives in integration.metadata.json (DSL examples are
# JSON-only); this file carries {category=...} annotations only.

[linearity]
# Sum rule (variadic via rest-pattern): split an integral of a sum. The
# pattern requires >= 2 operands and the splitter's tail is unwrapped by
# int-sum-one, so the degenerate empty sum (int (+) v) -- which nothing
# could close, stranding the search -- never forms. (Differentiation's
# rest-pattern linearity has the same latent shape but is rescued by its
# top-priority free-of? guard; integration has no analogous escape.)
@int-sum {category=structural}: (int (+ ?f ?g ?rest...) ?v) => (+ (int :f :v) (int (+ :g :rest...) :v))
# int-sum-one unwraps the unary-sum tail (int (+ f) v) that the splitter
# leaves. It is LOAD-BEARING under the NON-theory solve driver; under
# theory-normalized solve, normalize collapses (+ f) -> f before matching,
# so this rule is subsumed there but still required without a theory.
@int-sum-one {category=structural}: (int (+ ?f) ?v) => (int :f :v)
# Difference rule.
@int-diff {category=structural}: (int (- ?f ?g) ?v) => (- (int :f :v) (int :g :v))
# Constant multiple: pull a literal constant factor out (left and right).
# Both orders are load-bearing under the NON-theory solve driver: without a
# theory, (* x 5) stays as-is so only -right matches, while (* 5 x) needs
# -left. Under theory-normalized solve, normalize canonicalizes the constant
# to the front (* 5 x), so -left handles both and -right is subsumed there.
@int-const-mult-left {category=structural}: (int (* ?c:const ?f) ?v) => (* :c (int :f :v))
@int-const-mult-right {category=structural}: (int (* ?f ?c:const) ?v) => (* :c (int :f :v))

[table-power]
# Power rule: int x^n dx = x^(n+1)/(n+1), n != -1. Exact-rational coefficient
# via the exact folds (safe_div keeps 1/(n+1) a Fraction, never a float).
@int-power {category=power}: (int (^ ?v ?n:const) ?v) => (* (^ :v (! + :n 1)) (! / 1 (! + :n 1))) when (! != :n -1)
# int x dx = x^2/2 (the n=1 power case, given explicitly so x need not be x^1).
# 1/2 is a rational LITERAL (an exact Fraction atom), not a division expr.
@int-var {category=power}: (int ?v:var ?v) => (* (^ :v 2) 1/2)
# int 1 dx = x: integral of the constant 1.
@int-one {category=constant}: (int 1 ?v) => :v
# int c dx = c*x for a literal constant c (c != the variable).
@int-const {category=constant}: (int ?c:const ?v:var) => (* :c :v)

[table-reciprocal]
# int 1/x dx = ln|x|.
@int-recip {category=log}: (int (/ 1 ?v) ?v) => (ln (abs :v))
# int x^-1 dx = ln|x| (the n=-1 case excluded from the power rule).
@int-power-neg1 {category=log}: (int (^ ?v -1) ?v) => (ln (abs :v))

[table-exp-trig]
# int e^x dx = e^x.
@int-exp {category=exp}: (int (exp ?v) ?v) => (exp :v)
# int sin x dx = -cos x.
@int-sin {category=trig}: (int (sin ?v) ?v) => (- (cos :v))
# int cos x dx = sin x.
@int-cos {category=trig}: (int (cos ?v) ?v) => (sin :v)

[u-substitution]
# int g(inner) * inner' dx = G(inner), the chain rule in reverse, for the
# table functions whose antiderivative G is known. inner = v^2, inner' = 2v.
# ONE rule per function: the patterns match the THEORY-CANONICAL flat form
# (* 2 v (g (^ v 2))) -- numbers before symbols before compounds -- and the
# search runs with normalize_between under arithmetic.theory.json, so BOTH
# surface factor orders normalize to this one shape before matching.
# (Previously each rule was spelled twice, once per factor order; theory-
# normalized search deleted the -rev family with zero engine code.)
@int-usub-cos-sq {category=u-substitution}: (int (* 2 ?v (cos (^ ?v 2))) ?v) => (sin (^ :v 2))
@int-usub-sin-sq {category=u-substitution}: (int (* 2 ?v (sin (^ ?v 2))) ?v) => (- (cos (^ :v 2)))
@int-usub-exp-sq {category=u-substitution}: (int (* 2 ?v (exp (^ ?v 2))) ?v) => (exp (^ :v 2))

# NOTE on the fresh-variable u-sub form the original plan sketched: a rule
# whose skeleton repeats (fresh u) CANNOT route the inner integral through
# the table, because multiple same-base (fresh u) markers in one skeleton
# deliberately resolve to DISTINCT names (u, u1, ...), so the produced
# (int (cos u) u1) never matches (int (cos ?v) ?v). Verified live; the
# concrete collapsing rules above are the honest encoding. A general
# substitution mechanism needs engine support (a subst marker or
# search-introduces-subgoals), recorded as future work alongside the
# general by-parts schema below.

[by-parts]
# int(x * e^x) dx = x*e^x - int(e^x) dx, by parts with u = x, dv = e^x dx.
# Guarded to this product shape (left factor is the variable, right factor is
# exp of the variable). The produced inner integral int(e^x) closes by int-exp.
@int-byparts-x-exp {category=by-parts}: (int (* ?v (exp ?v)) ?v) => (- (* :v (exp :v)) (int (exp :v) :v))

# General by-parts schema (reference; NOT active this phase):
#   int(u * dv) dx = u*v - int(v * du) dx
# needs a way to (a) compute v = int dv and du = dd u, and (b) introduce a
# capture-avoiding fresh integration variable when u and v share names. A
# pure embedded-subgoal encoding is expressible --
#   (int (* ?u ?dv) ?v) => (- (* :u (int :dv :v)) (int (* (int :dv :v) (dd :u :v)) :v))
# -- but it branches the search on EVERY product and needs the dd rules
# co-loaded plus a cost function that rewards eliminating int nodes; the
# boomerang family (int(e^x sin x), where parts twice reproduces the
# original and one solves I = A - I algebraically) is beyond pure
# rewriting entirely. Left as the measured frontier; the concrete rule
# above is the active, tested, verifiable one.
