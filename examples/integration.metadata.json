    "examples": [
      {"in": "(int 1 x)", "out": "x"}
    ]
  },
  "int-const": {
    "examples": [
      {"in": "(int 5 x)", "out": "(* 5 x)"}
    ]
  },
  "int-recip": {
    "examples": [
      {"in": "(int (/ 1 x) x)", "out": "(ln (abs x))"}
    ]
  },
  "int-power-neg1": {
    "examples": [
      {"in": "(int (^ x -1) x)", "out": "(ln (abs x))"}
    ]
  },
  "int-exp": {
    "examples": [
      {"in": "(int (exp x) x)", "out": "(exp x)"}
    ]
  },
  "int-sin": {
    "examples": [
      {"in": "(int (sin x) x)", "out": "(- (cos x))"}
    ]
  },
  "int-cos": {
    "examples": [
      {"in": "(int (cos x) x)", "out": "(sin x)"}
    ]
  }
